# 共有モードのローカル設定（参照先パス・ネットワーク名。環境ごとに異なる）
/.shared.local.mk
local-setup.sh
prod-setup.sh
local-setup-prod-sync.sh
*.env
docker/line-mock-api/.env.mock
.user.ini
