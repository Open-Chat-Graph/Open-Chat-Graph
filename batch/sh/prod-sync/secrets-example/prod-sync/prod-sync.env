# 本番同期用 単一情報源 (サンプル)
# 実機ではプライベートリポから自動取得される実値が secrets/prod-sync/prod-sync.env に配置される。
# このファイルはフォーマットを示すための example。

# ============================================
# リモート (本番サーバ) 接続情報
# ============================================
REMOTE_SERVER=ssh-server.example.com
REMOTE_USER=remoteuser
REMOTE_PORT=22

# リモートサーバ上のドキュメントルート
REMOTE_PUBLIC_HTML=/home/remoteuser/example.com/public_html

# リモート MySQL 接続情報
REMOTE_MYSQL_USER=db_user
REMOTE_MYSQL_PASS="REPLACE_ME_WITH_ACTUAL_PASSWORD"

# リモート上で mysqldump を吐き出すパス
REMOTE_DUMP_DIR=/home/remoteuser/sqldump

# ============================================
# ローカル (Docker 内 MySQL) 接続情報
# ============================================
LOCAL_MYSQL_HOST=mysql
LOCAL_MYSQL_USER=root
LOCAL_MYSQL_PASS=test_root_pass
