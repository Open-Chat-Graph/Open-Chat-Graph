RewriteEngine On

# Pass Authorization header to PHP (required for Basic Auth in CGI/FastCGI environments like Xserver)
RewriteCond %{HTTP:Authorization} .
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Redirect Trailing Slashes If Not A Folder...
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^(.*)/$ /$1 [L,R=301]

# アイコンファイルは常にPHPルーティングを通す（ステージング環境での切り替えのため）
RewriteRule ^assets/icon-192x192\.png$ index.php [QSA,L]
RewriteRule ^favicon\.ico$ index.php [QSA,L]

# Send Requests To Front Controller...
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [QSA,L]

# Service Worker 関連ファイルはキャッシュさせない（autoUpdate を確実に拾わせる）。
# sw.js は basename でマッチするので /js/alpha/sw.js もここに該当する。
# 下の mod_expires による 30日キャッシュより優先して no-cache を効かせる。
<FilesMatch "^(sw\.js|registerSW\.js|push-sw\.js|workbox-.*\.js)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </IfModule>
  <IfModule mod_expires.c>
    ExpiresActive Off
  </IfModule>
</FilesMatch>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 30 days"
ExpiresByType application/javascript "access plus 30 days"
ExpiresByType image/jpeg "access plus 30 days"
ExpiresByType image/gif "access plus 30 days"
ExpiresByType image/png "access plus 30 days"
ExpiresByType image/svg+xml "access plus 30 days"
ExpiresByType image/webp "access plus 30 days"
ExpiresByType font/woff "access plus 30 days"
ExpiresByType font/woff2 "access plus 30 days"
ExpiresByType font/ttf "access plus 30 days"
ExpiresByType font/otf "access plus 30 days"
</IfModule>
